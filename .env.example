# ============================================================
# Renovo Co. CRM — Environment Variables
# ============================================================
# This is a Vanilla JS SPA — environment variables are NOT
# injected at build time. The Supabase URL and anon key are
# embedded directly in index.html (anon key is intentionally public).
#
# HOWEVER, these variables MUST be set as Supabase Edge Function
# Secrets (Dashboard → Project Settings → Edge Functions → Secrets)
# so the server-side functions work correctly.
# ============================================================

# ── Supabase (for reference — embedded in index.html) ────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://qofwwztuykerlcxfuutv.supabase.co
SUPABASE_ANON_KEY=sb_publishable_SRrLgFY1zPiplYahG6b5nw_oXKzWkVv

# ── Supabase Edge Function Secrets ───────────────────────────
# Set ALL of these in Supabase Dashboard → Project Settings → Edge Functions → Secrets
# These are NOT public — keep them secure.

# Service role key — used by edge functions to bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── QuickBooks Online OAuth ───────────────────────────────────
# Create an app at: https://developer.intuit.com/app/developer/appdetail
# Under "Keys & credentials" → copy Client ID and Client Secret
# Under "Redirect URIs" → add: https://your-project.supabase.co/functions/v1/quickbooks-callback
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret
QUICKBOOKS_REDIRECT_URI=https://qofwwztuykerlcxfuutv.supabase.co/functions/v1/quickbooks-callback

# Your deployed Vercel app URL (used to redirect back after QB OAuth)
APP_URL=https://renovo-co.vercel.app

# ── Booking Webhook ───────────────────────────────────────────
# The booking-webhook edge function uses SUPABASE_SERVICE_ROLE_KEY for auth.
# Configure your Zapier/Make zap to send:
#   Authorization: Bearer <SUPABASE_SERVICE_ROLE_KEY>
# to: https://your-project-id.supabase.co/functions/v1/booking-webhook
BOOKING_API_KEY=your-secure-webhook-api-key
