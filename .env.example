# ============================================================
# Renovo Co. CRM — Environment Variables
# Copy this file to .env.local for local development
# Add these to Vercel → Project Settings → Environment Variables
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── QuickBooks Online ─────────────────────────────────────────
# Create an app at: https://developer.intuit.com
# Set OAuth 2.0 Redirect URI to: https://your-app.vercel.app/integrations
QUICKBOOKS_CLIENT_ID=your-quickbooks-client-id
QUICKBOOKS_CLIENT_SECRET=your-quickbooks-client-secret
QUICKBOOKS_REDIRECT_URI=https://your-app.vercel.app/integrations

# ── Booking API (optional) ────────────────────────────────────
# Used for authenticating incoming webhook requests from booking platforms
# Set this as the Bearer token when calling the booking-webhook Edge Function
BOOKING_API_KEY=your-secure-webhook-api-key

# ── Supabase Edge Functions ───────────────────────────────────
# The SUPABASE_SERVICE_ROLE_KEY is used inside the booking-webhook Edge Function
# to bypass RLS. Set it in Supabase Dashboard → Edge Functions → Secrets,
# or it is automatically available as SUPABASE_SERVICE_ROLE_KEY in the function env.
